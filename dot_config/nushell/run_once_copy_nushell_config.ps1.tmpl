{{- $wt := .chezmoi.workingTree -}}
{{- if eq .chezmoi.os "windows" -}}
$ErrorActionPreference = "Stop"

$appDataDir = "$env:APPDATA\nushell"

# 确保 AppData\nushell 目录存在
if (-not (Test-Path $appDataDir)) {
    New-Item -ItemType Directory -Path $appDataDir -Force | Out-Null
}

# 为配置文件复制文件
$files = @("config.nu", "env.nu")
foreach ($file in $files) {
    $source = Join-Path "{{ $wt }}" "dot_config/nushell/$file"
    $target = Join-Path $appDataDir $file

    if (-not (Test-Path $source)) {
        Write-Warning "Source file not found: $source"
        continue
    }

    if (Test-Path $target) {
        $item = Get-Item $target
        if ($item.LinkType -eq "SymbolicLink") {
            Remove-Item $target -Force
        } else {
            $targetResolved = (Resolve-Path -LiteralPath $target).Path
            $sourceResolved = (Resolve-Path -LiteralPath $source).Path
            if ($targetResolved -eq $sourceResolved) {
                Write-Host "Source and target are the same, skipping copy"
                continue
            }
        }
    }

    Copy-Item $source $target -Force
    Write-Host "Copied $file to: $target"
}
{{- end -}}
