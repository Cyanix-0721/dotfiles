{{- if eq .chezmoi.os "windows" -}}
$ErrorActionPreference = "Stop"

# vfox 自动化处理
# NuShell ≥0.94 已原生支持从 ~/.config/nushell/ 读取配置
# config.nu / env.nu 由 chezmoi 直接部署到该路径，无需复制
$nuConfigDir = "$env:USERPROFILE\.config\nushell"

if (Get-Command vfox -ErrorAction SilentlyContinue) {
    & vfox activate nushell $nuConfigDir | Out-Null
    
    $vfoxNu = Join-Path $nuConfigDir "vfox.nu"
    if (Test-Path $vfoxNu) {
        Write-Host "Generated vfox.nu at $vfoxNu"
    }
}
{{- end -}}

